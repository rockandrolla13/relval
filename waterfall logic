```python
def validate_signals(signals):
    """
    Check signal quality metrics.
    """
    if len(signals) == 0:
        return {'warning': 'No signals generated'}
    
    long_signals = [s for s in signals if s['direction'] == 'LONG']
    short_signals = [s for s in signals if s['direction'] == 'SHORT']
    
    avg_long_zscore = np.mean([s['zscore'] for s in long_signals]) if long_signals else 0
    avg_short_zscore = np.mean([s['zscore'] for s in short_signals]) if short_signals else 0
    
    return {
        'n_signals': len(signals),
        'n_long': len(long_signals),
        'n_short': len(short_signals),
        'avg_long_zscore': avg_long_zscore,
        'avg_short_zscore': avg_short_zscore,
        'long_short_ratio': len(long_signals) / len(short_signals) if short_signals else float('inf')
    }
