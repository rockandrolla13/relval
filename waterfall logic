        market_price = bond['price']
        residual = model_price - market_price
        residuals.append(residual)
    
    rmse = np.sqrt(np.mean(np.array(residuals)**2))
    max_abs_residual = np.max(np.abs(residuals))
    
    checks = {
        'rmse_ok': rmse < 2.0,  # Less than 2 points
        'max_residual_ok': max_abs_residual < 5.0,  # No single bond > 5 points
        'rmse': rmse,
        'max_residual': max_abs_residual
    }
    
    return checks
```

### Hazard Rate Validity

```python
def validate_hazard_rate(theta, T_max=30):
    """
    Check hazard rate is always positive.
    """
    lambda_0, lambda_1, beta = theta
    
    t_grid = np.linspace(0, T_max, 100)
    
    for t in t_grid:
        lambda_t = lambda_0 + lambda_1 * np.exp(-beta * t)
        if lambda_t <= 0:
            return False, f"λ({t:.2f}) = {lambda_t:.6f} <= 0"
    
    return True, "OK"
```

