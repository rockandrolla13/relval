def calculate_risky_weighted_forward(T, theta, rf_curve):
    """
    Calculate risky-weighted average forward rate.
    
    r_b(T) = [∫₀ᵀ f(t)B(t)Q(t)dt] / [∫₀ᵀ B(t)Q(t)dt]
    
    Returns:
    --------
    r_b : float
        Risky-weighted forward rate (decimal)
    """
    # Quarterly grid
    n_steps = int(T * 4) + 1
    t_grid = np.linspace(0, T, n_steps)
    
    # Calculate components
    f_values = np.array([rf_curve.forward_rate(t) for t in t_grid])
    B_values = np.array([rf_curve.discount_factor(t) for t in t_grid])
    Q_values = np.array([survival_prob_from_theta(t, theta) for t in t_grid])
    
    # BQ product
    BQ = B_values * Q_values
    
    # Numerator: ∫ f(t)B(t)Q(t)dt
    numerator = np.trapz(f_values * BQ, t_grid)
    
    # Denominator: ∫ B(t)Q(t)dt = Π(T)
    denominator = np.trapz(BQ, t_grid)
    
    r_b = numerator / denominator
    
    return r_b
```

### Validation: Parity Equation

**Critical check** - this must always hold:

```
B(T)Q(T) + Ξ(T) + r_b(T)Π(T) = 1.0
```

```python
def validate_parity_equation(T, theta, rf_curve, tolerance=1e-6):
    """
    Validate parity equation holds.
    
    Returns True if valid, raises error otherwise.
    """
    B_T = rf_curve.discount_factor(T)
    Q_T = survival_prob_from_theta(T, theta)
    Xi = calculate_expected_loss(T, theta, rf_curve)
    r_b = calculate_risky_weighted_forward(T, theta, rf_curve)
    Pi = calculate_risky_pv01(T, theta, rf_curve)
    
    lhs = B_T * Q_T + Xi + r_b * Pi
    
    error = abs(lhs - 1.0)
    
    if error > tolerance:
        raise ValueError(
            f"Parity equation violated!\n"
            f"  B(T)Q(T) + Ξ(T) + r_b(T)Π(T) = {lhs:.10f}\n"
            f"  Expected: 1.0\n"
            f"  Error: {error:.2e}"
        )
    
    print(f"✓ Parity equation validated: {lhs:.10f} ≈ 1.0 (error: {error:.2e})")
    return True

